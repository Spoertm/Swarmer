@section Scripts {
<script>
    // Discord Simulation
    const discordMessages = document.getElementById('discord-messages');
    const streamers = [
        { name: 'Chupacabra', game: 'Devil Daggers', avatar: 'C' },
        { name: 'SpeedRunner99', game: 'Devil Daggers', avatar: 'S' },
        { name: 'DaggerMaster', game: 'HYPER DEMON', avatar: 'D' },
        { name: 'SorathFan', game: 'Devil Daggers', avatar: 'S' },
        { name: 'HyperPlayer', game: 'HYPER DEMON', avatar: 'H' },
    ];

    const colors = ['#1abc9c', '#2ecc71', '#3498db', '#9b59b6', '#e91e63', '#f1c40f', '#e67e22', '#e74c3c'];

    function getRandomStreamer() {
        return streamers[Math.floor(Math.random() * streamers.length)];
    }

    function getRandomColor() {
        return colors[Math.floor(Math.random() * colors.length)];
    }

    const streamTitles = [
        "almost pb...",
        "DD PB attempts",
        "HYPER DEMON",
        "praccing",
        "HYPER DEMON grinds",
        "Casual DD stream",
        "Going for 500 subs!"
    ];

    function getRandomTitle() {
        return streamTitles[Math.floor(Math.random() * streamTitles.length)];
    }

    function createDiscordMessage(streamer, isLive) {
        const statusText = isLive ? 'Live' : 'Offline';
        const thumbnailUrl = 'https://static-cdn.jtvnw.net/ttv-static/404_preview-440x248.jpg'
        const avatarColor = getRandomColor();
        const borderClass = isLive ? 'border-l-[#6441a4]' : 'border-l-[#000000]';
        const titleText = getRandomTitle();
        const timeString = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });

        const messageHtml = `
            <div class="flex items-start gap-3 py-2 transition-colors duration-100 group">
                
                <!-- Left: Swarmer Bot Avatar -->
                <img src="/images/Swarmer.png"
                    alt="Swarmer"
                    class="w-10 h-10 rounded-full flex-shrink-0 mt-0.5 object-cover">

                <!-- Right: Header + Message content -->
                <div class="flex flex-col gap-1 min-w-0">
                    
                    <!-- Header row: bot name + APP tag + timestamp -->
                    <div class="flex items-center gap-2">
                        <span class="font-semibold text-white text-sm hover:underline cursor-pointer">Swarmer</span>
                        <span class="text-[10px] font-semibold text-white bg-[#5865f2] px-1 py-0.5 rounded-sm leading-none">APP</span>
                        <span class="text-[#72767d] font-semibold text-xs">${timeString}</span>
                    </div>

                    <!-- The stream embed message -->
                    <div class="discord-message w-fit flex items-center px-3 py-2 rounded-sm bg-[#242429] border border-[#323237] border-l-4 ${borderClass}">
                        
                        <!-- Left component: avatar+name row, then status row -->
                        <div class="flex flex-col flex-1 min-w-0 gap-1">
                            <!-- Row 1: avatar + name -->
                            <div class="flex items-center gap-2">
                                <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=${streamer.name}&backgroundColor=${avatarColor.replace('#', '')}"
                                    alt="${streamer.name}"
                                    class="w-8 h-8 rounded-full flex-shrink-0 object-cover">
                                <span class="font-semibold text-white text-sm">${streamer.name}</span>
                            </div>
                            <!-- Row 2: status -->
                            <div class="flex items-center gap-0.5">
                                <span class="text-xs leading-none">${isLive ? '🔴' : '⚫'}</span>
                                <span class="text-[#dcddde] text-sm truncate">
                                    <span>${statusText}</span>| ${titleText}
                                </span>
                            </div>
                        </div>

                        <!-- Right component: thumbnail -->
                        <div class="flex-shrink-0 ml-4">
                            <img src="${thumbnailUrl}" alt="Stream thumbnail" class="w-20 h-12 object-cover rounded">
                        </div>

                    </div>
                    ${!isLive ? `<span class="text-[#72767d] text-xs mt-0.5">(edited)</span>` : ''}
                </div>
            </div>
        `;

        const tempDiv = document.createElement('div');
        tempDiv.innerHTML = messageHtml;
        const messageEl = tempDiv.firstElementChild;

        // Add to container
        discordMessages.appendChild(messageEl);

        // Remove old messages if too many - just remove immediately without transition
        while (discordMessages.children.length > 4) {
            discordMessages.firstElementChild?.remove();
        }
    }

    // Start the simulation
    function startSimulation() {
        // Initial messages
        setTimeout(() => createDiscordMessage(getRandomStreamer(), true), 500);
        setTimeout(() => createDiscordMessage(getRandomStreamer(), false), 1500);
        setTimeout(() => createDiscordMessage(getRandomStreamer(), true), 2500);

        // Continue adding messages
        setInterval(() => {
            const streamer = getRandomStreamer();
            const isLive = Math.random() > 0.4; // 60% chance of live
            createDiscordMessage(streamer, isLive);
        }, 3500);
    }

    // Start when page loads
    document.addEventListener('DOMContentLoaded', startSimulation);

