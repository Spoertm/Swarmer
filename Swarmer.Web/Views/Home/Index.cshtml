    document.querySelectorAll('.api-endpoint').forEach(endpoint => {
        endpoint.addEventListener('click', () => {
            const endpointType = endpoint.dataset.endpoint;
            const responseElement = document.getElementById('api-response');

            document.querySelectorAll('.api-endpoint').forEach(ep => {
                ep.classList.remove('border-blue-500', 'dark:border-blue-400');
