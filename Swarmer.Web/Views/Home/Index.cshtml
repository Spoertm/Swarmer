@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->
<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-[linear-gradient(135deg,_#1e40af_0%,_#3b82f6_50%,_#60a5fa_100%)] dark:bg-[linear-gradient(135deg,_#0f172a_0%,_#1e293b_50%,_#334155_100%)] transition-all duration-300"></div>
    <div class="absolute inset-0 bg-black/10 dark:bg-black/20 transition-all duration-300"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="animate-slide-up">
            <div class="mb-12">
                <div class="h-24 mx-auto mb-8 flex justify-center">
                    <img src="~/images/SwarmerWhite.svg" alt="Swarmer Logo" class="h-full w-auto object-contain animate-pulse-slow">
                </div>
                <h1 class="text-5xl md:text-7xl font-bold text-white mb-6 transition-colors duration-300">
                    Swarmer
                </h1>
                <p class="text-xl md:text-2xl text-blue-100 dark:text-slate-200 mb-8 max-w-4xl mx-auto leading-relaxed transition-colors duration-300">
                    A Discord bot for the <span class="text-white font-semibold">Devil Daggers</span> community that notifies when <span class="text-white font-semibold">Devil Daggers</span> and <span class="text-white font-semibold">HYPER DEMON</span> Twitch streams go live.
                </p>
            </div>

            <div class="flex flex-col sm:flex-row gap-6 justify-center items-center mb-16">
                <a href="https://discord.gg/jMRumVerj2" target="_blank"
                   class="px-8 py-4 bg-indigo-600 hover:bg-indigo-700 dark:bg-indigo-500 dark:hover:bg-indigo-600 text-white font-semibold rounded-xl transition-all duration-300 transform hover:scale-105 shadow-lg">
                    <i class="fab fa-discord mr-2"></i>
                    Join DD Pals
                </a>
                <a href="https://ko-fi.com/chupacabra4129" target="_blank"
                   class="px-8 py-4 bg-orange-500 hover:bg-orange-600 dark:bg-orange-600 dark:hover:bg-orange-700 text-white font-semibold rounded-xl transition-all duration-300 transform hover:scale-105 shadow-lg">
                    <i class="fas fa-coffee mr-3"></i>
                    Support Development
                </a>
                <a href="#demo"
                   class="px-8 py-4 bg-white/10 backdrop-blur-md border border-white/20 shadow-lg text-white font-semibold rounded-xl transition-all duration-300 transform hover:scale-105 hover:bg-white/20 dark:hover:bg-white/30">
                    <i class="fas fa-play mr-2"></i>
                    See It In Action
                </a>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
                <div class="bg-white/10 dark:bg-white/5 backdrop-blur-md border border-white/20 dark:border-white/10 shadow-lg rounded-2xl p-8 text-center transition-all duration-300 hover:bg-white/20 dark:hover:bg-white/10">
                    <div class="text-4xl font-bold text-white mb-3">24/7</div>
                    <div class="text-blue-100 dark:text-slate-200 text-lg transition-colors duration-300">Uptime</div>
                    <div class="text-blue-200 dark:text-slate-300 text-sm mt-2 transition-colors duration-300">Always monitoring</div>
                </div>
                <div class="bg-white/10 dark:bg-white/5 backdrop-blur-md border border-white/20 dark:border-white/10 shadow-lg rounded-2xl p-8 text-center transition-all duration-300 hover:bg-white/20 dark:hover:bg-white/10">
                    <div class="text-4xl font-bold text-white mb-3">2</div>
                    <div class="text-blue-100 dark:text-slate-200 text-lg transition-colors duration-300">Games</div>
                    <div class="text-blue-200 dark:text-slate-300 text-sm mt-2 transition-colors duration-300">Devil Daggers & HYPER DEMON</div>
                </div>
                <div class="bg-white/10 dark:bg-white/5 backdrop-blur-md border border-white/20 dark:border-white/10 shadow-lg rounded-2xl p-8 text-center transition-all duration-300 hover:bg-white/20 dark:hover:bg-white/10">
                    <div class="text-4xl font-bold text-white mb-3">0</div>
                    <div class="text-blue-100 dark:text-slate-200 text-lg transition-colors duration-300">Duplicates</div>
                    <div class="text-blue-200 dark:text-slate-300 text-sm mt-2 transition-colors duration-300">Smart posting</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Discord Simulation Section -->
<section id="demo" class="py-20 bg-gray-50 dark:bg-gray-900 transition-colors duration-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
            <h2 class="text-4xl md:text-5xl font-bold mb-6 text-gray-900 dark:text-gray-100 transition-colors duration-300">
                <i class="fab fa-discord mr-3 text-indigo-600 dark:text-indigo-400"></i>
                Live Demo
            </h2>
            <p class="text-xl text-gray-600 dark:text-gray-300 max-w-3xl mx-auto transition-colors duration-300">
                See how Swarmer posts stream notifications in real-time
            </p>
        </div>

        <div class="max-w-3xl mx-auto">
            <!-- Discord Channel Simulation -->
            <div class="bg-[#1a1a1e] rounded-xl overflow-hidden shadow-2xl">
                <!-- Discord Header -->
                <div class="bg-[#1a1a1e] px-6 py-3 border-b border-[#323237] flex items-center">
                    <i class="fas fa-hashtag text-gray-400 mr-4"></i>
                    <span class="text-white font-semibold">twitch-streams</span>
                </div>

                <!-- Discord Messages Container -->
                <div id="discord-messages" class="p-4 space-y-2 h-[35rem] overflow-hidden">
                    <!-- Messages will be injected here by JavaScript -->
                </div>

                <!-- Discord Input -->
                <div class="bg-[#242429] mx-4 mb-4 rounded-lg p-3 flex items-center border border-[#323237]">
                    <div class="w-8 h-8 rounded-lg hover:bg-[#636363] flex items-center justify-center mr-3 cursor-pointer transition-colors flex-shrink-0">
                        <i class="fas fa-plus text-[#b5bac1]"></i>
                    </div>
                    <span class="text-[#6d6f78] select-none flex-1">Message #twitch-streams</span>
                    <div class="flex items-center space-x-3 text-[#b5bac1]">
                        <i class="fas fa-gift text-lg cursor-pointer hover:text-white transition-colors"></i>
                        <span class="font-bold text-sm cursor-pointer hover:text-white transition-colors">GIF</span>
                        <i class="fas fa-note-sticky text-lg cursor-pointer hover:text-white transition-colors"></i>
                        <i class="far fa-smile text-lg cursor-pointer hover:text-white transition-colors"></i>
                        <i class="fas fa-shapes text-lg cursor-pointer hover:text-white transition-colors"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

