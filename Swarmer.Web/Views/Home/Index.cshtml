<!-- API Section -->
<section id="api" class="py-20 bg-gray-50 dark:bg-gray-900 transition-colors duration-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
            <h2 class="text-4xl md:text-5xl font-bold mb-6 text-gray-900 dark:text-gray-100 transition-colors duration-300">
                <i class="fas fa-code mr-3 text-blue-600 dark:text-blue-400"></i>
                Developer API
            </h2>
            <p class="text-xl text-gray-600 dark:text-gray-300 max-w-3xl mx-auto transition-colors duration-300">
                Access Swarmer's stream data through our REST API
            </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <div>
                <h3 class="text-2xl font-bold mb-6 text-gray-900 dark:text-gray-100 transition-colors duration-300">API Endpoints</h3>
                <div class="space-y-4">
                    <div class="bg-white dark:bg-gray-800 rounded-xl p-6 cursor-pointer transition-all duration-300 hover:shadow-lg border border-gray-200 dark:border-gray-700 api-endpoint" data-endpoint="streams">
                        <div class="flex items-center justify-between mb-2">
                            <span class="font-mono text-sm bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-400 px-3 py-1 rounded transition-colors duration-300">GET</span>
                            <span class="text-sm text-gray-500 dark:text-gray-400 font-mono transition-colors duration-300">/streams</span>
                        </div>
                        <p class="text-gray-600 dark:text-gray-300 transition-colors duration-300">Get all active streams</p>
                        <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Optional: ?game=devil+daggers</p>
                    </div>

                    <div class="bg-white dark:bg-gray-800 rounded-xl p-6 cursor-pointer transition-all duration-300 hover:shadow-lg border border-gray-200 dark:border-gray-700 api-endpoint" data-endpoint="streams-dd">
                        <div class="flex items-center justify-between mb-2">
                            <span class="font-mono text-sm bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-400 px-3 py-1 rounded transition-colors duration-300">GET</span>
                            <span class="text-sm text-gray-500 dark:text-gray-400 font-mono transition-colors duration-300">/streams?game=devil+daggers</span>
                        </div>
                        <p class="text-gray-600 dark:text-gray-300 transition-colors duration-300">Filter by Devil Daggers</p>
                    </div>

                    <div class="bg-white dark:bg-gray-800 rounded-xl p-6 cursor-pointer transition-all duration-300 hover:shadow-lg border border-gray-200 dark:border-gray-700 api-endpoint" data-endpoint="streams-hd">
                        <div class="flex items-center justify-between mb-2">
                            <span class="font-mono text-sm bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-400 px-3 py-1 rounded transition-colors duration-300">GET</span>
                            <span class="text-sm text-gray-500 dark:text-gray-400 font-mono transition-colors duration-300">/streams?game=hyper+demon</span>
                        </div>
                        <p class="text-gray-600 dark:text-gray-300 transition-colors duration-300">Filter by HYPER DEMON</p>
                    </div>
                </div>

                <div class="mt-8">
                    <a href="/scalar/v1" target="_blank" class="inline-flex border border-gray-300 dark:border-gray-600 backdrop-blur-md rounded-xl items-center px-6 py-3 bg-blue-600 dark:bg-blue-500 hover:bg-blue-700 dark:hover:bg-blue-600 text-white font-semibold transition-all duration-300 transform hover:scale-105">
                        <i class="fas fa-book mr-2"></i>
                        View Documentation
                    </a>
                </div>
            </div>

            <div class="bg-gray-900 dark:bg-gray-950 rounded-2xl p-6 overflow-hidden border border-gray-700 dark:border-gray-600 transition-colors duration-300">
                <div class="flex items-center mb-4">
                    <div class="flex space-x-2">
                        <div class="w-3 h-3 bg-red-500 rounded-full"></div>
                        <div class="w-3 h-3 bg-yellow-500 rounded-full"></div>
                        <div class="w-3 h-3 bg-green-500 rounded-full"></div>
                    </div>
                    <span class="ml-4 text-gray-400 text-sm">API Response</span>
                </div>
                <pre class="text-green-400 text-sm overflow-x-auto font-mono scrollbar-thin" id="api-response"><code>[
  {
    "id": "123456789",
    "userName": "StreamersName",
    "title": "Devil Daggers - Going for 1000+!",
    "gameName": "Devil Daggers",
    "viewerCount": 42,
    "thumbnailUrl": "https://static-cdn...",
    "startedAt": "2024-01-15T14:30:00Z"
  }
]</code></pre>
