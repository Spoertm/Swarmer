@{
    ViewData["Title"] = "Privacy";
}

<section class="py-20 bg-gray-50 dark:bg-gray-900 transition-colors duration-300 min-h-screen">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="text-4xl font-bold mb-8 text-gray-900 dark:text-gray-100 transition-colors duration-300">
            <i class="fas fa-shield-alt mr-3 text-blue-600 dark:text-blue-400"></i>
            Privacy Policy
        </h1>

        <div class="bg-white dark:bg-gray-800 rounded-2xl p-8 shadow-lg border border-gray-200 dark:border-gray-700 transition-colors duration-300">
            <p class="text-gray-600 dark:text-gray-300 mb-6 transition-colors duration-300">
                Swarmer is a Discord bot that monitors Twitch streams for Devil Daggers and HYPER DEMON. This privacy policy explains what data we collect and how we use it.
            </p>

            <h2 class="text-2xl font-bold mb-4 text-gray-900 dark:text-gray-100 transition-colors duration-300">Data We Collect</h2>
            <ul class="list-disc list-inside text-gray-600 dark:text-gray-300 mb-6 space-y-2 transition-colors duration-300">
                <li>Discord channel IDs where the bot is configured to post</li>
                <li>Twitch stream information (publicly available)</li>
                <li>Message IDs of posted stream notifications (for updating offline status)</li>
            </ul>

            <h2 class="text-2xl font-bold mb-4 text-gray-900 dark:text-gray-100 transition-colors duration-300">How We Use Data</h2>
            <p class="text-gray-600 dark:text-gray-300 mb-6 transition-colors duration-300">
                All data collected is used solely for the purpose of providing stream notifications. We do not share or sell any data to third parties.
            </p>

            <h2 class="text-2xl font-bold mb-4 text-gray-900 dark:text-gray-100 transition-colors duration-300">Contact</h2>
            <p class="text-gray-600 dark:text-gray-300 transition-colors duration-300">
                If you have any questions about this privacy policy, please contact us on Discord: Chupacabra#1513
            </p>
        </div>
    </div>
</section>
