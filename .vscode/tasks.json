{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build",
			"command": "dotnet",
			"type": "process",
			"args": ["build", "${workspaceFolder}/Swarmer.slnx"],
			"problemMatcher": "$msCompile"
		},
		{
			"label": "test",
			"command": "dotnet",
			"type": "process",
			"args": ["test", "${workspaceFolder}/Swarmer.slnx"],
			"problemMatcher": "$msCompile",
			"group": {
				"kind": "test",
				"isDefault": true
			}
		},
		{
			"label": "clean",
			"command": "dotnet",
			"type": "process",
			"args": ["clean", "${workspaceFolder}/Swarmer.slnx"],
			"problemMatcher": "$msCompile"
		}
	]
}
