{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build",
			"command": "dotnet",
			"type": "process",
			"args": ["build", "${workspaceFolder}/Swarmer.slnx"],
			"problemMatcher": "$msCompile"
		},
		{
			"label": "tailwind-watch",
			"command": "npx",
			"type": "process",
			"args": [
				"@tailwindcss/cli",
				"-i",
				"./Styles/input.css",
				"-o",
				"./wwwroot/css/site.css",
				"--watch"
			],
			"options": {
				"cwd": "${workspaceFolder}/Swarmer.Web"
			},
			"isBackground": true,
			"problemMatcher": []
		},
		{
			"label": "test",
			"command": "dotnet",
			"type": "process",
			"args": ["test", "${workspaceFolder}/Swarmer.slnx"],
			"problemMatcher": "$msCompile",
			"group": {
				"kind": "test",
				"isDefault": true
			}
		},
		{
			"label": "clean",
			"command": "dotnet",
			"type": "process",
			"args": ["clean", "${workspaceFolder}/Swarmer.slnx"],
			"problemMatcher": "$msCompile"
		},
		{
			"label": "ef database update",
			"command": "dotnet",
			"type": "process",
			"args": [
				"ef",
				"database",
				"update",
				"--project",
				"${workspaceFolder}/Swarmer.Domain/Swarmer.Domain.csproj",
				"--startup-project",
				"${workspaceFolder}/Swarmer.Web/Swarmer.Web.csproj"
			],
			"problemMatcher": []
		}
	]
}
