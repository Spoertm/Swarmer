{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build",
			"command": "dotnet",
			"type": "process",
			"args": ["build", "${workspaceFolder}/Swarmer.slnx"],
			"problemMatcher": "$msCompile"
		},
		{
			"label": "test",
			"command": "dotnet",
			"type": "process",
			"args": ["test", "${workspaceFolder}/Swarmer.slnx"],
			"problemMatcher": "$msCompile",
			"group": {
				"kind": "test",
				"isDefault": true
			}
		},
		{
			"label": "clean",
			"command": "dotnet",
			"type": "process",
			"args": ["clean", "${workspaceFolder}/Swarmer.slnx"],
			"problemMatcher": "$msCompile"
		},
		{
			"label": "ef database update",
			"command": "dotnet",
			"type": "process",
			"args": [
				"ef",
				"database",
				"update",
				"--project",
				"${workspaceFolder}/Swarmer.Domain/Swarmer.Domain.csproj",
				"--startup-project",
				"${workspaceFolder}/Swarmer.Web.Server/Swarmer.Web.Server.csproj"
			],
			"problemMatcher": []
		}
	]
}
